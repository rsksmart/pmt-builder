# Bitcoin Core JSON-RPC settings for regtest when using
# tool/getInformationReadyForRegisterBtcTransaction.js with network "regtest".
#
# Copy to .env in the project root and adjust values. The tool loads .env
# automatically via dotenv (no manual export needed).
#
# Or pass variables inline for a single run (see README).

# JSON-RPC endpoint (HTTP). Default in code if unset: http://127.0.0.1:18444
BITCOIND_RPC_URL=http://127.0.0.1:18444

# RPC authentication (Basic). Leave empty if your node allows unauthenticated localhost RPC.
BITCOIND_RPC_USER=
BITCOIND_RPC_PASSWORD=
