# Bitcoin Core JSON-RPC settings for regtest when using
# tool/getInformationReadyForRegisterBtcTransaction.js or
# tool/getInformationReadyForRegisterBtcCoinbaseTransaction.js with network "regtest".
#
# Copy to .env in the project root and adjust values. The tool loads .env
# automatically via dotenv.
#

# JSON-RPC endpoint (HTTP). Default in code if unset: http://127.0.0.1:18443 (Bitcoin Core regtest RPC)
BITCOIND_RPC_URL=http://127.0.0.1:18443

# RPC authentication (Basic). Leave empty if your node allows unauthenticated localhost RPC.
BITCOIND_RPC_USER=
BITCOIND_RPC_PASSWORD=
